{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@qubickit/sdk": ["src/index.ts"],
      "@qubickit/sdk/*": ["src/*"]
    }
  },
  "include": ["src", "tsup.config.ts", "vitest.config.ts", "types/**/*.d.ts"]
}
