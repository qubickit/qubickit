{
  "name": "@qubickit/core",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "bun test",
    "schemas:download": "bun run ./scripts/download-schemas.ts",
    "schemas:generate": "bun run ./scripts/generate-models.ts",
    "schemas:diff": "bun run ./scripts/schema-diff.ts"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/swagger2openapi": "^7.0.4"
  }
}
